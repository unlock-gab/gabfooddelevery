# ─── Copy this file to .env and fill in the values ───────────────────────

# PostgreSQL password (generate a strong random password)
DB_PASSWORD=change_me_strong_password_here

# JWT secret for authentication tokens (generate with: openssl rand -hex 32)
JWT_SECRET=change_me_random_secret_here

# Port for the web interface (default: 3000)
# Dokploy will handle external routing via Traefik, so usually leave as 3000
WEB_PORT=3000
