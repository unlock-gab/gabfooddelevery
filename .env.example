# ─── Copy this file to .env and fill in the values ───────────────────────

# PostgreSQL connection string (from Dokploy database)
DATABASE_URL=postgresql://fooddelivery:PASSWORD@HOST:5432/fooddelivery

# JWT secret for authentication tokens (generate with: openssl rand -hex 32)
JWT_SECRET=change_me_random_secret_here

# Port for the web interface (Dokploy Traefik will route externally)
WEB_PORT=3000
