FROM node:24-alpine AS builder

RUN corepack enable && corepack prepare pnpm@10 --activate

WORKDIR /app

COPY pnpm-workspace.yaml pnpm-lock.yaml package.json ./
COPY lib/ ./lib/
COPY artifacts/tasty-crousty/ ./artifacts/tasty-crousty/
COPY artifacts/api-server/package.json ./artifacts/api-server/package.json
COPY artifacts/mobile/package.json ./artifacts/mobile/package.json
COPY artifacts/mockup-sandbox/package.json ./artifacts/mockup-sandbox/package.json

RUN pnpm install --frozen-lockfile

ENV PORT=3000
ENV BASE_PATH=/
ENV NODE_ENV=production

RUN pnpm --filter @workspace/tasty-crousty run build

# ── Nginx production image ─────────────────────────────────────────────
FROM nginx:1.27-alpine

COPY docker/nginx.conf /etc/nginx/conf.d/nginx.conf.template
COPY --from=builder /app/artifacts/tasty-crousty/dist/public /usr/share/nginx/html

EXPOSE 80

# Replace API_HOST placeholder with environment variable at container start
CMD ["/bin/sh", "-c", "envsubst '$API_HOST' < /etc/nginx/conf.d/nginx.conf.template > /etc/nginx/conf.d/default.conf && nginx -g 'daemon off;'"]
