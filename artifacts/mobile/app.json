{
  "expo": {
    "name": "food delivery",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fooddelivery",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F0A000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.unlockgab.fooddelivery",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "food delivery utilise votre position pour remplir automatiquement votre adresse de livraison."
      }
    },
    "android": {
      "package": "com.unlockgab.fooddelivery",
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#F0A000"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://food.gab-digital.com"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "food delivery utilise votre position pour remplir automatiquement votre adresse de livraison."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
